# data.yaml — YOLOv8-pose dataset configuration for golf club keypoints
#
# This file is auto-generated when downloading via Roboflow.
# Shown here for reference. The actual file lives at:
#   scripts/train-club-model/datasets/golf_club_pose/data.yaml
#
# IMPORTANT: Use the ABSOLUTE path when passing to yolo CLI.

path: /absolute/path/to/scripts/train-club-model/datasets/golf_club_pose
train: train/images
val: valid/images
test: test/images

# Single class
names:
  0: club

# 3 keypoints (grip, shaft midpoint, clubhead), each with (x, y, visibility)
kpt_shape: [3, 3]
flip_idx: [0, 1, 2]
