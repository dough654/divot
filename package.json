{
  "name": "divot",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --dev-client",
    "dev:tunnel": "expo start --dev-client --tunnel",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:android": "npx eas-cli build --platform android --profile development",
    "build:ios": "npx eas-cli build --platform ios --profile development",
    "build:android:preview": "npx eas-cli build --platform android --profile preview",
    "build:ios:preview": "npx eas-cli build --platform ios --profile preview",
    "build:android:prod": "npx eas-cli build --platform android --profile production",
    "build:ios:prod": "npx eas-cli build --platform ios --profile production",
    "build:local:iphone": "./scripts/local-build.sh ios --device iphone",
    "build:local:ipad": "./scripts/local-build.sh ios --device ipad",
    "build:local:ipad-pro": "./scripts/local-build.sh ios --device ipad-pro",
    "build:local:s22": "./scripts/local-build.sh android --device s22",
    "build:local:s10-tablet": "./scripts/local-build.sh android --device s10-tablet",
    "build:local:android": "./scripts/local-build.sh android",
    "build:local:ios": "./scripts/local-build.sh ios",
    "build:local:android:preview": "./scripts/local-build.sh android --profile preview",
    "build:local:ios:preview": "./scripts/local-build.sh ios --profile preview",
    "install:iphone": "./scripts/local-install.sh ios --device iphone",
    "install:ipad": "./scripts/local-install.sh ios --device ipad",
    "install:ipad-pro": "./scripts/local-install.sh ios --device ipad-pro",
    "install:s22": "./scripts/local-install.sh android --device s22",
    "install:s10-tablet": "./scripts/local-install.sh android --device s10-tablet",
    "eas:configure": "npx eas-cli build:configure",
    "eas:login": "npx eas-cli login",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.23",
    "@config-plugins/react-native-webrtc": "^13.0.0",
    "@expo-google-fonts/darker-grotesque": "^0.4.2",
    "@expo-google-fonts/manrope": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/netinfo": "11.4.1",
    "@react-native-community/slider": "5.0.1",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.33",
    "expo-apple-authentication": "^8.0.8",
    "expo-auth-session": "^7.0.10",
    "expo-av": "~16.0.8",
    "expo-blur": "~15.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "^15.0.8",
    "expo-dev-client": "~6.0.20",
    "expo-file-system": "~19.0.21",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-location": "~19.0.8",
    "expo-media-library": "~18.2.1",
    "expo-router": "~6.0.23",
    "expo-screen-orientation": "~9.0.8",
    "expo-secure-store": "^15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-video-thumbnails": "~10.0.8",
    "expo-web-browser": "~15.0.10",
    "ffmpeg-kit-react-native": "^6.0.2",
    "posthog-react-native": "^4.31.1",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-purchases": "^9.10.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-vision-camera": "^4.7.3",
    "react-native-web": "~0.21.0",
    "react-native-webrtc": "^124.0.7",
    "react-native-worklets": "0.5.1",
    "react-native-worklets-core": "^1.6.2",
    "react-native-zeroconf": "^0.14.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.0",
    "dotenv": "^17.3.1",
    "patch-package": "^8.0.1",
    "react-test-renderer": "19.1.0",
    "typescript": "~5.9.2",
    "vitest": "^4.0.18"
  },
  "overrides": {
    "@clerk/clerk-expo": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@clerk/types": {
      "react": "$react",
      "react-dom": "$react-dom"
    },
    "@clerk/shared": {
      "react": "$react",
      "react-dom": "$react-dom"
    }
  },
  "private": true
}
